# Результаты компиляции полностью воспроизводятся из исходников и пакетов.
**/bin/
**/obj/
.build/
DerivedData/

# Portable-публикация, архивы и локальные ярлыки не являются исходниками.
dist/
*.zip
*.lnk

# Локальные данные приложения не должны попадать в систему контроля версий.
Data/
dist/portable/*/Data/

# Временные каталоги создаются атомарной portable-публикацией.
dist/portable/.*-publish/
dist/portable/.*-package/

# Пользовательские файлы IDE относятся к конкретному компьютеру.
.vs/
*.user
*.suo
*.xcuserstate

# Диагностические и временные файлы не являются частью проекта.
*.log
*.tmp
*.bak
.DS_Store
