<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Light">
            <SolidColorBrush x:Key="MainWindowBackground" Color="#F2F2F2"/>
            <SolidColorBrush x:Key="CardBackgroundFillColorDefault" Color="#F9F9F9"/>
            <SolidColorBrush x:Key="CardBorderBrush" Color="#E0E0E0"/>
            <SolidColorBrush x:Key="SidebarBackground" Color="#F2F2F2"/>
            <SolidColorBrush x:Key="TextFillColorPrimary" Color="#1E1E1E"/>
            <SolidColorBrush x:Key="TextFillColorSecondary" Color="#6E6E6E"/>
            <SolidColorBrush x:Key="SystemAccentColor" Color="#0078D4"/>
            <SolidColorBrush x:Key="AppScrollBarTrackBrush" Color="#14000000"/>
            <SolidColorBrush x:Key="AppScrollBarThumbBrush" Color="#7A6B4EFF"/>
            <!-- WinUI TabView templates ожидают эти кисти в словарях темы.
                 Мы определяем их явно, чтобы любой внутренний шаблон мог
                 загрузиться даже на старте приложения без падения XAML. -->
            <SolidColorBrush x:Key="TabViewScrollButtonBackground" Color="#00FFFFFF"/>
            <SolidColorBrush x:Key="TabViewScrollButtonBackgroundPressed" Color="#14000000"/>
            <SolidColorBrush x:Key="TabViewScrollButtonBackgroundPointerOver" Color="#0F000000"/>
            <SolidColorBrush x:Key="TabViewScrollButtonBackgroundDisabled" Color="#00FFFFFF"/>
            <SolidColorBrush x:Key="TabViewScrollButtonForeground" Color="#6E6E6E"/>
            <SolidColorBrush x:Key="TabViewScrollButtonForegroundPressed" Color="#6E6E6E"/>
            <SolidColorBrush x:Key="TabViewScrollButtonForegroundPointerOver" Color="#1E1E1E"/>
            <SolidColorBrush x:Key="TabViewScrollButtonForegroundDisabled" Color="#A0A0A0"/>
            <SolidColorBrush x:Key="TabViewScrollButtonBorderBrush" Color="#00FFFFFF"/>
            <SolidColorBrush x:Key="TabViewScrollButtonBorderBrushPressed" Color="#00FFFFFF"/>
            <SolidColorBrush x:Key="TabViewScrollButtonBorderBrushPointerOver" Color="#00FFFFFF"/>
            <SolidColorBrush x:Key="TabViewScrollButtonBorderBrushDisabled" Color="#00FFFFFF"/>
        </ResourceDictionary>
        <ResourceDictionary x:Key="Dark">
            <SolidColorBrush x:Key="MainWindowBackground" Color="#1E1E1E"/>
            <SolidColorBrush x:Key="CardBackgroundFillColorDefault" Color="#2C2C2C"/>
            <SolidColorBrush x:Key="CardBorderBrush" Color="#3C3C3C"/>
            <SolidColorBrush x:Key="SidebarBackground" Color="#1E1E1E"/>
            <SolidColorBrush x:Key="TextFillColorPrimary" Color="#F2F2F2"/>
            <SolidColorBrush x:Key="TextFillColorSecondary" Color="#A0A0A0"/>
            <SolidColorBrush x:Key="SystemAccentColor" Color="#4CC2FF"/>
            <SolidColorBrush x:Key="AppScrollBarTrackBrush" Color="#24FFFFFF"/>
            <SolidColorBrush x:Key="AppScrollBarThumbBrush" Color="#B58B7CFF"/>
            <!-- Те же ключи для тёмной темы, но с чуть более заметным hover. -->
            <SolidColorBrush x:Key="TabViewScrollButtonBackground" Color="#00FFFFFF"/>
            <SolidColorBrush x:Key="TabViewScrollButtonBackgroundPressed" Color="#1FFFFFFF"/>
            <SolidColorBrush x:Key="TabViewScrollButtonBackgroundPointerOver" Color="#18FFFFFF"/>
            <SolidColorBrush x:Key="TabViewScrollButtonBackgroundDisabled" Color="#00FFFFFF"/>
            <SolidColorBrush x:Key="TabViewScrollButtonForeground" Color="#A0A0A0"/>
            <SolidColorBrush x:Key="TabViewScrollButtonForegroundPressed" Color="#F2F2F2"/>
            <SolidColorBrush x:Key="TabViewScrollButtonForegroundPointerOver" Color="#F2F2F2"/>
            <SolidColorBrush x:Key="TabViewScrollButtonForegroundDisabled" Color="#707070"/>
            <SolidColorBrush x:Key="TabViewScrollButtonBorderBrush" Color="#00FFFFFF"/>
            <SolidColorBrush x:Key="TabViewScrollButtonBorderBrushPressed" Color="#00FFFFFF"/>
            <SolidColorBrush x:Key="TabViewScrollButtonBorderBrushPointerOver" Color="#00FFFFFF"/>
            <SolidColorBrush x:Key="TabViewScrollButtonBorderBrushDisabled" Color="#00FFFFFF"/>
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>
</ResourceDictionary>
