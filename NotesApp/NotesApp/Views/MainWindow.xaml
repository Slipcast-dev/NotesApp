<Window x:Class="NotesApp.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="using:NotesApp.Views"
        Title="NotesApp"
        Closed="Window_Closed">
    <Grid x:Name="RootGrid" Background="{ThemeResource MainWindowBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid x:Name="AppTitleBar" Grid.Row="0" Background="Transparent">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <!--
                    При расширении содержимого в системный заголовок Windows
                    размещает кнопки свернуть, развернуть и закрыть поверх
                    правой части окна. Резервируем под них отдельную область,
                    чтобы прикладные кнопки не пересекались с системными.
                -->
                <ColumnDefinition Width="144"/>
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal"
                        Margin="10,0,0,0"
                        Spacing="6"
                        VerticalAlignment="Center">
                <Image Source="ms-appx:///Assets/NotebookPurple.png"
                       Width="20"
                       Height="20"
                       Stretch="Uniform"/>
                <TextBlock Text="NotesApp"
                           VerticalAlignment="Center"
                           Style="{StaticResource WindowCaptionTextBlockStyle}"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" Margin="14,0,14,14">
            <Grid.ColumnDefinitions>
                <!--
                    Панели расположены в порядке рабочего процесса:
                    поиск и выбор заметки, редактирование, управление тегами.
                    Центральная колонка остается гибкой и получает все
                    свободное пространство при изменении размера окна.
                -->
                <ColumnDefinition Width="380"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="250"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Margin="0,0,8,0"
                    Padding="0"
                    Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBox x:Name="SearchBox"
                             Header="{x:Bind Strings.Search}"
                             Margin="12,12,12,10"
                             PlaceholderText="{x:Bind Strings.SearchPlaceholder}"
                             Text="{x:Bind ViewModel.NotesListViewModel.SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                    <!--
                        В узкой левой панели элементы фильтрации разбиты на
                        две строки. Это сохраняет кнопку создания заметки
                        видимой и не заставляет переключатель обрезаться.
                    -->
                    <Grid Grid.Row="1" Margin="12,0,12,10" ColumnSpacing="8" RowSpacing="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <ComboBox x:Name="SortComboBox"
                                  HorizontalAlignment="Stretch"
                                  PlaceholderText="{x:Bind Strings.SortBy}"
                                  SelectedValuePath="Tag"
                                  SelectedValue="{x:Bind ViewModel.NotesListViewModel.CurrentSorting, Mode=TwoWay}">
                            <ComboBoxItem Tag="updateddesc" Content="{x:Bind Strings.RecentFirst}"/>
                            <ComboBoxItem Tag="updatedasc" Content="{x:Bind Strings.OldestFirst}"/>
                            <ComboBoxItem Tag="titleasc" Content="{x:Bind Strings.TitleAscending}"/>
                            <ComboBoxItem Tag="titledesc" Content="{x:Bind Strings.TitleDescending}"/>
                            <ComboBoxItem Tag="createddesc" Content="{x:Bind Strings.CreatedNewestFirst}"/>
                            <ComboBoxItem Tag="createdasc" Content="{x:Bind Strings.CreatedOldestFirst}"/>
                        </ComboBox>

                        <Button Grid.Column="1"
                                Content="{x:Bind Strings.NewNote}"
                                Command="{x:Bind ViewModel.NotesListViewModel.CreateNewNoteCommand}"/>

                        <ToggleSwitch Grid.Row="1"
                                      Grid.ColumnSpan="2"
                                      Header="{x:Bind Strings.ShowDeleted}"
                                      IsOn="{x:Bind ViewModel.NotesListViewModel.ShowDeleted, Mode=TwoWay}"
                                      OffContent="{x:Bind Strings.Hide}"
                                      OnContent="{x:Bind Strings.Show}"/>
                    </Grid>

                    <local:NotesListView Grid.Row="2" x:Name="NotesListControl" Margin="0,0,0,12"/>
                </Grid>
            </Border>

            <Border Grid.Column="1"
                    Margin="8,0,8,0"
                    Padding="0"
                    Style="{StaticResource CardStyle}">
                <local:NoteEditorView x:Name="NoteEditorControl" Margin="12"/>
            </Border>

            <Border Grid.Column="2"
                    Margin="8,0,0,0"
                    Padding="0"
                    Background="{ThemeResource SidebarBackground}"
                    Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid Margin="12,12,12,8" ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="{x:Bind Strings.Tags}"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource SubtitleTextBlockStyle}"/>
                        <Button Grid.Column="1"
                                Content="{x:Bind Strings.NewTag}"
                                Command="{x:Bind ViewModel.TagsListViewModel.CreateTagCommand}"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"/>
                    </Grid>
                    <ScrollViewer Grid.Row="1">
                        <local:TagsListView x:Name="TagsListViewControl"/>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!--
            Настройки перенесены в нижний правый угол рабочего пространства.
            Кнопка расположена поверх пустой нижней области панели тегов и
            остается доступной независимо от длины списков.
        -->
        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    Spacing="8"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Margin="0,0,28,28"
                    Canvas.ZIndex="10">
            <Button x:Name="StorageButton"
                    Click="StorageButton_Click"/>
            <Button Content="{x:Bind Strings.Settings}"
                    Command="{x:Bind ViewModel.OpenSettingsCommand}"/>
        </StackPanel>

        <!--
            Настройки выводятся поверх основного интерфейса. Такой контейнер
            использует уже существующее состояние ViewModel и не создает
            отдельное окно, которому пришлось бы вручную передавать тему,
            размер шрифта и текущую локализацию.
        -->
        <Grid Grid.RowSpan="2"
              Background="#99000000"
              Visibility="{Binding IsSettingsOpen, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid Width="520"
                  MaxHeight="700"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center">
                <local:SettingsView x:Name="SettingsViewControl"
                                    DataContext="{x:Bind ViewModel.SettingsViewModel}"/>
                <Button Content="{x:Bind Strings.Close}"
                        Command="{x:Bind ViewModel.CloseSettingsCommand}"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="0,12,12,0"/>
            </Grid>
        </Grid>
    </Grid>
</Window>
