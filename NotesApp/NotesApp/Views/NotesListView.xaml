<UserControl x:Class="NotesApp.Views.NotesListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:models="using:NotesApp.Models"
             mc:Ignorable="d">
    <Grid x:Name="NotesListGrid"
          ColumnSpacing="4">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="12"/>
        </Grid.ColumnDefinitions>

        <ListView x:Name="NotesList"
                  Tag="{x:Bind Strings}"
                  ItemsSource="{x:Bind ViewModel.Notes}"
                  SelectedItem="{x:Bind ViewModel.SelectedNote, Mode=TwoWay}"
                  SelectionMode="Single"
                  IsItemClickEnabled="True"
                  ScrollViewer.VerticalScrollBarVisibility="Hidden"
                  ScrollViewer.VerticalScrollMode="Enabled"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                  Loaded="NotesList_Loaded"
                  ItemClick="NotesList_ItemClick">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:Note">
                    <Grid Padding="8" Margin="0,0,0,4">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="{x:Bind Title}" FontWeight="SemiBold"/>

                        <TextBlock Grid.Row="1"
                                   Text="{x:Bind UpdatedAt}"
                                   Style="{StaticResource SmallTextBlockStyle}"
                                   Margin="0,0,0,0"/>

                        <FlyoutBase.AttachedFlyout>
                            <MenuFlyout>
                                <MenuFlyoutItem Text="{Binding ElementName=NotesList, Path=Tag.Delete}"
                                                Command="{Binding ElementName=NotesList, Path=DataContext.DeleteNoteCommand}"
                                                CommandParameter="{Binding}"/>
                                <MenuFlyoutItem Text="{Binding ElementName=NotesList, Path=Tag.Restore}"
                                                Visibility="{x:Bind IsDeleted, Converter={StaticResource BoolToVisibilityConverter}}"
                                                Command="{Binding ElementName=NotesList, Path=DataContext.RestoreNoteCommand}"
                                                CommandParameter="{Binding}"/>
                            </MenuFlyout>
                        </FlyoutBase.AttachedFlyout>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!--
            Отдельный ScrollBar не зависит от системной настройки Windows
            "автоматически скрывать полосы прокрутки" и всегда остается
            видимым справа от результатов поиска.
        -->
        <Border Grid.Column="1"
                x:Name="NotesScrollTrack"
                Opacity="0.26"
                Width="12"
                CornerRadius="6"
                Background="{ThemeResource AppScrollBarTrackBrush}"
                PointerEntered="NotesScrollTrack_PointerEntered"
                PointerExited="NotesScrollTrack_PointerExited"
                PointerPressed="NotesScrollTrack_PointerPressed"
                PointerMoved="NotesScrollTrack_PointerMoved"
                PointerReleased="NotesScrollTrack_PointerReleased"
                PointerCanceled="NotesScrollTrack_PointerReleased"
                PointerCaptureLost="NotesScrollTrack_PointerCaptureLost">
            <Grid>
                <!--
                    Собственный индикатор нужен, потому что системный шаблон
                    ScrollBar может скрывать ползунок настройкой Windows.
                    Его позиция синхронизируется с реальным ScrollViewer.
                -->
                <Border x:Name="NotesScrollThumb"
                        Opacity="0.58"
                        Width="8"
                        Height="40"
                        Margin="2"
                        VerticalAlignment="Top"
                        CornerRadius="4"
                        IsHitTestVisible="False"
                        Background="{ThemeResource AppScrollBarThumbBrush}">
                    <Border.RenderTransform>
                        <TranslateTransform x:Name="NotesThumbTransform"/>
                    </Border.RenderTransform>
                </Border>
                <ScrollBar x:Name="NotesScrollBar"
                           Opacity="0"
                           IsHitTestVisible="False"
                           Orientation="Vertical"
                           Minimum="0"
                           SmallChange="48"
                           Scroll="NotesScrollBar_Scroll"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
